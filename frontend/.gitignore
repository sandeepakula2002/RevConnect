####################################
# Git Ignore – Full Stack Project
# Angular + Node + Java (Optional)
####################################

# ================================
# Compiled / Build Output
# ================================
/dist
/tmp
/out-tsc
/bazel-out
/build
/coverage

# ================================
# Node / NPM / Yarn
# ================================
/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ================================
# Angular
# ================================
/.angular/cache
/.angular

# ================================
# Environment Files
# ================================
.env
.env.*
!.env.example

# ================================
# IDE & Editors
# ================================
.idea/
.project
.classpath
.settings/
.c9/
*.launch
*.sublime-workspace
*.sublime-project

# ================================
# Visual Studio Code
# ================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# ================================
# Logs
# ================================
logs/
*.log
libpeerconnection.log
testem.log

# ================================
# OS System Files
# ================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ================================
# Java / Spring Boot (if backend uses Java)
# ================================
/target
*.class
*.jar
*.war
*.ear
*.iml

# ================================
# Python (if used)
# ================================
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.env/

# ================================
# Database / Local files
# ================================
*.sqlite
*.db
*.sql

# ================================
# Miscellaneous
# ================================
/connect.lock
/typings
.cache/
